<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground"
    android:fitsSystemWindows="true">

    <!-- HEADER DENGAN DUA IKON (PROFIL & FAVORIT) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="?android:attr/colorBackground"
        android:elevation="4dp"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="EndemikDB"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Ikon Profil -->
        <ImageView
            android:id="@+id/btnGoToProfile"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@id/btnToggleDark"
            android:layout_marginEnd="12dp"
            android:src="@drawable/fotoi"
            android:scaleType="centerCrop"
            android:background="@color/card_bg"
            android:elevation="2dp" />

        <!-- Ikon Toggle Dark Mode -->
        <ImageView
            android:id="@+id/btnToggleDark"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@id/btnGoToLikes"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_moon"
            android:tint="?android:attr/textColorPrimary" />

        <!-- Ikon Favorit -->
        <ImageView
            android:id="@+id/btnGoToLikes"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_love_on" />
    </RelativeLayout>

    <!-- CONTAINER PENCARIAN & REGION -->
    <LinearLayout
        android:id="@+id/layoutSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@color/background_app">

        <!-- Baris 1: Pencarian Nama -->
        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Cari nama..."
            android:textSize="14sp"
            android:paddingHorizontal="15dp"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="10dp"
            android:background="@drawable/search_bg"
            android:textColor="?android:attr/textColorPrimary"
            android:inputType="text" />

        <!-- Baris 2: Dropdown Wilayah (Region) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/search_bg"
            android:paddingHorizontal="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_dialog_map"
                android:layout_marginEnd="8dp"/>

            <Spinner
                android:id="@+id/spinnerWilayah"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null" />
        </LinearLayout>
    </LinearLayout>

    <!-- LIST DATA -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvEndemik"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="8dp" />

</LinearLayout>